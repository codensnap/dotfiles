
eval "$(/opt/homebrew/bin/brew shellenv)"
export PS1="$ "
# Enable colors in ls output
export CLICOLOR=1

# Customize the default colors (optional, this is the default Mac scheme)
export LSCOLORS=ExFxCxDxBxegedabagacad

# Set an alias for ls to use -alG (all files, long format, colorized)
alias ls='ls -alG'



